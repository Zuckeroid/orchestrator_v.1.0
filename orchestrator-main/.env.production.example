NODE_ENV=production
PORT=3000
API_BIND_HOST=127.0.0.1
ADMIN_UI_PORT=8080
ADMIN_UI_BIND_HOST=0.0.0.0
ADMIN_UI_ORIGIN=http://YOUR_ORCHESTRATOR_HOST:8080
ADMIN_UI_BASIC_AUTH_USER=admin
ADMIN_UI_BASIC_AUTH_PASSWORD=replace_with_strong_admin_ui_password

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=orchestrator
DB_PASS=replace_with_strong_db_password
DB_NAME=orchestrator
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Provision cleanup
PROVISION_CLEANUP_ENABLED=true
PROVISION_CLEANUP_CRON="*/15 * * * *"
PROVISION_CLEANUP_LIMIT=50

# Security
ADMIN_API_KEY=replace_with_random_admin_key
WEBHOOK_API_KEY=replace_with_random_webhook_key
WEBHOOK_SIGNING_SECRET=replace_with_random_webhook_secret
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
DATA_ENCRYPTION_KEY=replace_with_random_data_key

# Billing Provider
BILLING_PROVIDER=fossbilling
BILLING_API_URL=https://my-storage.org/
BILLING_API_KEY=replace_with_billing_api_key

# VPN / 3x-ui
VPN_PROVIDER=3x-ui
VPN_TIMEOUT=5000
VPN_3XUI_LOGIN_PATH=login
VPN_3XUI_INBOUNDS_PATH=panel/api/inbounds
VPN_3XUI_SUB_PATH=sub
VPN_3XUI_TLS_REJECT_UNAUTHORIZED=true
VPN_3XUI_CLIENT_FLOW=xtls-rprx-vision
VPN_3XUI_CLIENT_TOTAL_GB=0
VPN_3XUI_CLIENT_EXPIRY_TIME=0

# S3 Storage Provider
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=replace_when_storage_is_enabled
STORAGE_SECRET_KEY=replace_when_storage_is_enabled
STORAGE_TIMEOUT=5000
