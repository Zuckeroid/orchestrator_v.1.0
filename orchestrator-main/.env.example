PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=orchestrator
DB_PASS=orchestrator
DB_NAME=orchestrator
DB_SYNCHRONIZE=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Security
WEBHOOK_API_KEY=secret
WEBHOOK_SIGNING_SECRET=secret
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300
DATA_ENCRYPTION_KEY=base64-secret

# Billing Provider
BILLING_PROVIDER=fossbilling
BILLING_API_URL=https://billing.example.com
BILLING_API_KEY=secret

# VPN / 3x-ui
VPN_TIMEOUT=5000

# S3 Storage Provider
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=access
STORAGE_SECRET_KEY=secret
STORAGE_TIMEOUT=5000
